{% assign collection = collections[section.settings.collection] %}

<section class="featured-collection section-padding">
  <div class="container">
    <div class="section-header animate-on-scroll">
      <div>
        {% if section.settings.title != blank %}
          <div class="accent-line"></div>
          <h2 class="section-title">{{ section.settings.title }}</h2>
          <p class="section-subtitle">Entdecke unsere neuesten Sportswear-Highlights</p>
        {% endif %}
      </div>
      {% if collection != blank %}
        <a href="{{ collection.url }}" class="view-all-link">ALLE ANZEIGEN →</a>
      {% else %}
        <a href="/collections/all" class="view-all-link">ALLE ANZEIGEN →</a>
      {% endif %}
    </div>

    <div class="grid-4">
      {% if collection != blank and collection.products.size > 0 %}
        {% for product in collection.products limit: 8 %}
          <div class="product-card animate-on-scroll delay-{{ forloop.index | modulo: 4 | plus: 1 }}">
            <div class="product-card-image-wrap">
              <a href="{{ product.url }}">
                {% if product.featured_image %}
                  <img
                    src="{{ product.featured_image | img_url: '500x500', crop: 'center' }}"
                    alt="{{ product.featured_image.alt | escape | default: product.title }}"
                    loading="lazy"
                    width="500"
                    height="500"
                  >
                {% else %}
                  <div class="product-image-placeholder">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                      <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21,15 16,10 5,21"/>
                    </svg>
                  </div>
                {% endif %}
              </a>

              {% if product.compare_at_price > product.price %}
                <div class="product-card-badge sale">SALE</div>
              {% elsif product.created_at > 'now' | date: '%s' | minus: 2592000 | date: '%Y-%m-%dT%H:%M:%SZ' %}
                <div class="product-card-badge">NEU</div>
              {% endif %}

              <div class="product-card-overlay">
                <a href="{{ product.url }}" class="quick-view-btn">DETAILS ANSEHEN</a>
              </div>
            </div>

            <div class="product-card-info">
              {% if product.vendor %}
                <div class="product-card-vendor">{{ product.vendor }}</div>
              {% endif %}

              <h3 class="product-card-title">
                <a href="{{ product.url }}">{{ product.title }}</a>
              </h3>

              <div class="product-card-price">
                <span class="price-current">{{ product.price | money }}</span>
                {% if product.compare_at_price > product.price %}
                  <span class="price-compare">{{ product.compare_at_price | money }}</span>
                  {% assign savings = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price %}
                  <span class="price-savings">-{{ savings }}%</span>
                {% endif %}
              </div>

              {% if product.available %}
                <button
                  class="product-card-btn"
                  data-add-to-cart
                  data-variant-id="{{ product.variants.first.id }}"
                  data-product-id="{{ product.variants.first.id }}"
                  aria-label="{{ product.title }} in den Warenkorb"
                >
                  IN DEN WARENKORB
                </button>
              {% else %}
                <button class="product-card-btn" disabled>AUSVERKAUFT</button>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      {% else %}
        <div class="no-products">
          <h3>Noch keine Produkte</h3>
          <p>Produkte werden bald verfügbar sein.</p>
          <a href="/collections/all" class="btn btn-outline">ALLE PRODUKTE</a>
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Collection",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titel",
      "default": "NEUE KOLLEKTION"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Kollektion"
    }
  ],
  "presets": [
    {
      "name": "Featured Collection"
    }
  ]
}
{% endschema %}
