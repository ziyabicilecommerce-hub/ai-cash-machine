<div class="cart-page">
  <div class="container">
    <div class="cart-header">
      <h1 class="cart-page-title">DEIN <span>WARENKORB</span></h1>
    </div>

    {% if cart.item_count > 0 %}
      <div class="cart-layout">
        <!-- Cart Items -->
        <div>
          <form action="/cart" method="post" id="cart-form">
            <table class="cart-table">
              <thead>
                <tr>
                  <th colspan="2">Produkt</th>
                  <th>Preis</th>
                  <th>Menge</th>
                  <th>Gesamt</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                {% for item in cart.items %}
                  <tr class="cart-item">
                    <td style="width:90px;">
                      <div class="cart-item-image-wrap">
                        {% if item.image %}
                          <a href="{{ item.url }}">
                            <img
                              src="{{ item.image | img_url: '160x160', crop: 'center' }}"
                              alt="{{ item.title | escape }}"
                              width="80"
                              height="80"
                              loading="lazy"
                            >
                          </a>
                        {% else %}
                          <div style="width:80px;height:80px;background:var(--bg3);display:flex;align-items:center;justify-content:center;border-radius:4px;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" opacity="0.3">
                              <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21,15 16,10 5,21"/>
                            </svg>
                          </div>
                        {% endif %}
                      </div>
                    </td>
                    <td>
                      <div class="cart-item-details">
                        <div class="cart-item-title">
                          <a href="{{ item.url }}">{{ item.product.title }}</a>
                        </div>
                        {% unless item.variant.title == 'Default Title' %}
                          <div class="cart-item-variant">{{ item.variant.title }}</div>
                        {% endunless %}
                        {% if item.selling_plan_allocation %}
                          <div class="cart-item-variant">{{ item.selling_plan_allocation.selling_plan.name }}</div>
                        {% endif %}
                      </div>
                    </td>
                    <td>
                      <span class="cart-item-price">{{ item.price | money }}</span>
                    </td>
                    <td>
                      <div class="cart-quantity">
                        <button type="button" class="cart-qty-btn" data-cart-qty="minus" aria-label="Menge verringern">−</button>
                        <input
                          class="cart-qty-input"
                          type="number"
                          name="updates[]"
                          value="{{ item.quantity }}"
                          min="0"
                          max="99"
                          data-line="{{ forloop.index }}"
                          aria-label="Menge für {{ item.title }}"
                        >
                        <button type="button" class="cart-qty-btn" data-cart-qty="plus" aria-label="Menge erhöhen">+</button>
                      </div>
                    </td>
                    <td>
                      <span class="cart-item-total">{{ item.line_price | money }}</span>
                    </td>
                    <td>
                      <button
                        type="button"
                        class="cart-remove-btn"
                        data-remove-line="{{ forloop.index }}"
                        aria-label="{{ item.title }} aus Warenkorb entfernen"
                        title="Entfernen"
                      >✕</button>
                    </td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>

            <div style="display:flex;gap:16px;margin-top:24px;flex-wrap:wrap;">
              <a href="/collections/all" class="btn btn-secondary">← WEITER EINKAUFEN</a>
              <button type="submit" name="update" class="btn btn-outline">WARENKORB AKTUALISIEREN</button>
            </div>
          </form>
        </div>

        <!-- Cart Summary -->
        <div class="cart-summary">
          <h2 class="cart-summary-title">BESTELLÜBERSICHT</h2>

          <div class="cart-summary-row">
            <span>Zwischensumme</span>
            <span>{{ cart.total_price | money }}</span>
          </div>
          <div class="cart-summary-row">
            <span>Versand</span>
            <span style="color:var(--primary);">Kostenlos ab 50€</span>
          </div>
          {% if cart.total_discounts > 0 %}
            <div class="cart-summary-row" style="color:#ff4444;">
              <span>Rabatt</span>
              <span>-{{ cart.total_discounts | money }}</span>
            </div>
          {% endif %}
          <div class="cart-summary-row total">
            <span>Gesamtbetrag</span>
            <span class="cart-summary-value">{{ cart.total_price | money }}</span>
          </div>
          <p style="font-size:12px;color:var(--text-muted);margin-top:12px;">
            inkl. MwSt. Versandkosten werden beim Checkout berechnet.
          </p>

          <!-- Discount Code -->
          <form action="/cart" method="post" style="margin-top:24px;">
            <div style="display:flex;gap:8px;">
              <input
                type="text"
                name="discount"
                placeholder="Gutscheincode"
                class="form-input"
                style="flex:1;"
                aria-label="Gutscheincode eingeben"
              >
              <button type="submit" class="btn btn-outline" style="padding:12px 16px;font-size:14px;">OK</button>
            </div>
          </form>

          <a href="/checkout" class="cart-checkout-btn" aria-label="Zur Kasse gehen">
            ZUR KASSE →
          </a>
          <a href="/collections/all" class="cart-continue-btn">
            Weiter einkaufen
          </a>

          <!-- Trust Badges -->
          <div style="margin-top:24px;padding-top:24px;border-top:1px solid var(--border);display:flex;flex-wrap:wrap;gap:16px;justify-content:center;">
            <div style="display:flex;align-items:center;gap:6px;font-size:12px;color:var(--text-muted);">
              <span>🔒</span> Sichere Zahlung
            </div>
            <div style="display:flex;align-items:center;gap:6px;font-size:12px;color:var(--text-muted);">
              <span>↩️</span> 30 Tage Rückgabe
            </div>
            <div style="display:flex;align-items:center;gap:6px;font-size:12px;color:var(--text-muted);">
              <span>🚚</span> Schnelle Lieferung
            </div>
          </div>
        </div>
      </div>

    {% else %}
      <!-- Empty Cart -->
      <div class="cart-empty">
        <div class="cart-empty-icon">🛒</div>
        <h2>DEIN WARENKORB IST LEER</h2>
        <p>Entdecke unsere Kollektion und füge Artikel zu deinem Warenkorb hinzu.</p>
        <a href="/collections/all" class="btn btn-primary">JETZT SHOPPEN</a>
      </div>
    {% endif %}
  </div>
</div>
