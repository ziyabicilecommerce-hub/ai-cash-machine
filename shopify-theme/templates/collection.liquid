<div class="collection-header">
  <div class="container">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span>/</span>
      <a href="/collections/all">Shop</a>
      <span>/</span>
      <span style="color:var(--text);">{{ collection.title }}</span>
    </nav>
    <h1>
      <span style="color:var(--primary);">{{ collection.title | upcase }}</span>
    </h1>
    {% if collection.description != blank %}
      <p class="collection-desc">{{ collection.description }}</p>
    {% endif %}
    <div class="collection-meta">
      <span class="collection-count">{{ collection.products_count }} Produkte</span>
    </div>
  </div>
</div>

<div class="collection-products">
  <div class="container">
    {% if collection.products.size > 0 %}
      <div class="grid-4">
        {% for product in collection.products %}
          <div class="product-card animate-on-scroll">
            <div class="product-card-image-wrap">
              <a href="{{ product.url }}">
                {% if product.featured_image %}
                  <img
                    src="{{ product.featured_image | img_url: '500x500', crop: 'center' }}"
                    alt="{{ product.featured_image.alt | escape | default: product.title }}"
                    loading="lazy"
                    width="500"
                    height="500"
                  >
                {% else %}
                  <div class="product-image-placeholder">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                      <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21,15 16,10 5,21"/>
                    </svg>
                  </div>
                {% endif %}
              </a>

              {% if product.compare_at_price > product.price %}
                <div class="product-card-badge sale">SALE</div>
              {% endif %}

              <div class="product-card-overlay">
                <a href="{{ product.url }}" class="quick-view-btn">DETAILS ANSEHEN</a>
              </div>
            </div>

            <div class="product-card-info">
              {% if product.vendor %}
                <div class="product-card-vendor">{{ product.vendor }}</div>
              {% endif %}

              <h3 class="product-card-title">
                <a href="{{ product.url }}">{{ product.title }}</a>
              </h3>

              <div class="product-card-price">
                {% if product.price_varies %}
                  <span class="price-current">Ab {{ product.price_min | money }}</span>
                {% else %}
                  <span class="price-current">{{ product.price | money }}</span>
                {% endif %}
                {% if product.compare_at_price > product.price %}
                  <span class="price-compare">{{ product.compare_at_price | money }}</span>
                {% endif %}
              </div>

              {% if product.available %}
                <button
                  class="product-card-btn"
                  data-add-to-cart
                  data-variant-id="{{ product.variants.first.id }}"
                  aria-label="{{ product.title }} in den Warenkorb legen"
                >
                  IN DEN WARENKORB
                </button>
              {% else %}
                <button class="product-card-btn" disabled>AUSVERKAUFT</button>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>

      <!-- Pagination -->
      {% if paginate.pages > 1 %}
        <div class="pagination">
          {% if paginate.previous %}
            <a href="{{ paginate.previous.url }}" aria-label="Vorherige Seite">&laquo;</a>
          {% endif %}
          {% for part in paginate.parts %}
            {% if part.is_link %}
              <a href="{{ part.url }}">{{ part.title }}</a>
            {% else %}
              {% if part.title == paginate.current_page %}
                <span class="current">{{ part.title }}</span>
              {% else %}
                <span>{{ part.title }}</span>
              {% endif %}
            {% endif %}
          {% endfor %}
          {% if paginate.next %}
            <a href="{{ paginate.next.url }}" aria-label="Nächste Seite">&raquo;</a>
          {% endif %}
        </div>
      {% endif %}

    {% else %}
      <div class="no-products">
        <h3>Keine Produkte gefunden</h3>
        <p>Diese Kollektion enthält noch keine Produkte.</p>
        <a href="/collections/all" class="btn btn-outline">ALLE PRODUKTE</a>
      </div>
    {% endif %}
  </div>
</div>
